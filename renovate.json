{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "Etc/UTC",
  "schedule": ["before 6am on monday"],
  "minimumReleaseAge": "3 days",
  "labels": ["dependencies"],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "dependencyDashboard": true,
  "dependencyDashboardApproval": true,
  "configMigration": true,
  "lockFileMaintenance": {
    "enabled": true
  },
  "pre-commit": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "GitHub Actions: pin by SHA with the tag comment auto-updated, grouped into one PR.",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "pinDigests": true
    }
  ],
  "customManagers": [
    {
      "description": "Inline `pip install pre-commit==<x>` in ci.yml → PyPI pre-commit. Keeps the CI-pinned version current.",
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/ci\\.yml$/"],
      "matchStrings": ["pre-commit==(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "pre-commit",
      "datasourceTemplate": "pypi",
      "versioningTemplate": "pep440"
    }
  ]
}
